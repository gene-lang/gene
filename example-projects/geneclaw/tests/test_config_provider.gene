#!/usr/bin/env gene run

(import LLM_PROVIDER get_public_config get_public_config_gene secret_configured from "config")

(var expected ($env/EXPECTED_PROVIDER || "openai"))
(var public_config (get_public_config))
(var rendered (get_public_config_gene))

(var secret_values [
  ($env/OPENAI_API_KEY || "")
  ($env/ANTHROPIC_API_KEY || "")
  ($env/ANTHROPIC_AUTH_TOKEN || $env/ANTHROPIC_OAUTH_TOKEN || "")
  ($env/SLACK_SIGNING_SECRET || "")
  ($env/SLACK_BOT_TOKEN || "")
  ($env/SLACK_APP_TOKEN || "")
  ($env/SLACK_AGENTX_TOKEN || "")
  ($env/BRAVE_API_KEY || "")
])

(assert (LLM_PROVIDER == expected))
(assert (public_config/llm/provider == expected))
(assert (public_config/llm/openai/api_key == "hidden"))
(assert (public_config/llm/anthropic/api_key == "hidden"))
(assert (public_config/llm/anthropic/auth_token == "hidden"))
(assert (public_config/slack/signing_secret == "hidden"))
(assert (public_config/slack/bot_token == "hidden"))
(assert (public_config/slack/app_token == "hidden"))
(assert (public_config/slack/agentx_token == "hidden"))
(assert (public_config/search/brave_api_key == "hidden"))
(assert (public_config/llm/openai/api_key_configured == (secret_configured ($env/OPENAI_API_KEY || ""))))
(assert (public_config/llm/anthropic/api_key_configured == (secret_configured ($env/ANTHROPIC_API_KEY || ""))))
(assert (public_config/llm/anthropic/auth_token_configured == (secret_configured ($env/ANTHROPIC_AUTH_TOKEN || $env/ANTHROPIC_OAUTH_TOKEN || ""))))
(assert (public_config/slack/signing_secret_configured == (secret_configured ($env/SLACK_SIGNING_SECRET || ""))))
(assert (public_config/slack/bot_token_configured == (secret_configured ($env/SLACK_BOT_TOKEN || ""))))
(assert (public_config/slack/app_token_configured == (secret_configured ($env/SLACK_APP_TOKEN || ""))))
(assert (public_config/slack/agentx_token_configured == (secret_configured ($env/SLACK_AGENTX_TOKEN || ""))))
(assert (public_config/search/brave_api_key_configured == (secret_configured ($env/BRAVE_API_KEY || ""))))
(assert (rendered .contain "^llm"))
(assert (rendered .contain "^slack"))
(assert (rendered .contain "hidden"))

(for secret in secret_values
  (if_not secret/.empty
    (assert ((rendered .contain secret) == false))
  )
)

(println "ok")
