# ----------------------------------------------------------------------------
# 14) Async, Futures, callbacks, async I/O, actors
# ----------------------------------------------------------------------------

(println "=== 14) async/concurrency ===")

(var completed_future (async 42))
(println "await completed future:" (await completed_future))

(var manual_future (new gene/Future))
(manual_future .on_success (fn [value] (println "manual future success:" value)))
(manual_future .complete "ready")
(println "manual await:" (await ^timeout 0.5 manual_future))

(var failed_future (new gene/Future))
(failed_future .fail "future failed")
(try
  (await failed_future)
catch *
  (println "future failure observed on await:" $ex/message)
)

(var cancelled_future (new gene/Future))
(cancelled_future .cancel)
(try
  (await cancelled_future)
catch CancellationException
  (println "future cancellation observed:" $ex/message)
catch *
  (println "future cancellation fallback:" $ex/message)
)

# Async file I/O:
# (await (gene/io/write_async "build/tour.txt" "hello"))
# (println (await (gene/io/read_async "build/tour.txt")))

# Actors: actor runtime must be enabled before spawning.
(gene/actor/enable ^workers 2)

(var counter_actor
  (gene/actor/spawn
    ^state 0
    (fn [ctx msg state]
      (case msg/kind
      when "increment"
        (+ state msg/by)

      when "get"
        (ctx .reply state)
        state

      when "stop"
        (ctx .reply "stopping")
        (ctx .stop)
        state

      else state
      )
    )
  )
)

(counter_actor .send {^kind "increment" ^by 5})
(counter_actor .send {^kind "increment" ^by 7})
(println "actor reply:" (await (counter_actor .send_expect_reply {^kind "get"})))

# RECOMMENDATION: add structured concurrency:
#   (await_all [f1 f2 f3])
#   (await_any [f1 f2])
# RECOMMENDATION: add actor supervision/monitoring and restart strategies.
# RECOMMENDATION: add async iteration:
#   (for await row in stream ...)


# ----------------------------------------------------------------------------
# 15) Generators and iterator protocol
# ----------------------------------------------------------------------------

(println "=== 15) generators ===")

(var id_gen (ids* 100 3))
(println "manual generator:" id_gen/.next id_gen/.next id_gen/.next id_gen/.next)

(var id_total 0)
(for generated_id in (ids* 10 4)
  (id_total += generated_id)
)
(println "for over generator:" id_total)

(var squares
  (fn ^^generator [max]
    (var i 0)
    (while (i < max)
      (yield (i * i))
      (i += 1)
    )
  )
)
(var square_gen (squares 5))
(while (square_gen .has_next)
  (println "square:" (square_gen .next))
)

# RECOMMENDATION: replace/augment ^^generator with a more obvious anonymous syntax:
#   (fn* [max] ...)
# RECOMMENDATION: avoid a yieldable `not_found` sentinel conflict by using an iterator result wrapper.


