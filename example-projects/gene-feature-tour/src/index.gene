#!/usr/bin/env gene run

# index.gene — Complete Gene language feature tour.
# Run from project root:
#   ../../bin/gene run src/index.gene
#
# RECOMMENDATION: publish a generated language reference from parser + tests so syntax,
# docs, and executable examples cannot drift.

#<

Block comments use #< ... >#.

This file is deliberately broad. Some sections demonstrate beta or experimental
surfaces; those are marked in comments.

>#


# ----------------------------------------------------------------------------
# 0) Compile-time evaluation
# ----------------------------------------------------------------------------

(comptime
  (var mode ($env "GENE_TOUR_MODE" "fast"))

  (if (mode == "fast")
    (fn generated_policy [] "fast")
  else
    (fn generated_policy [] "safe")
  )
)
# `comptime` emits direct definitions/imports/classes/etc. into this compilation unit.
# RECOMMENDATION: add `(emit form)` so dynamically constructed quoted AST can be emitted.
# RECOMMENDATION: support loops, user-defined calls, limited file reads, and compiler reflection
# inside comptime in a controlled/sandboxed way.


# ----------------------------------------------------------------------------
# 1) Modules, imports, aliases, nested namespace imports
# ----------------------------------------------------------------------------

(import a b from "./mathbits")
(import ops/inc:inc1 from "./mathbits")
(import ops/[double:twice triple:thrice] from "./mathbits")

(import
  UserId
  DisplayName
  Priority
  Renderable
  Scored
  Note
  Task
  TimedTask
  Backlog
  Multiplier
  make_task
  make_counter
  positive_add
  annotated_add
  identity
  ids*
  trace!
  from "./catalog"
)

# Package-qualified import shape:
# (import upcase from "index" ^pkg "x/some_lib")
# (import value from "feature" of "x/some_lib")
# RECOMMENDATION: add selective re-export syntax, e.g. `(export imported_name)`.
# RECOMMENDATION: add dynamic/conditional imports with clear caching semantics.


# ----------------------------------------------------------------------------
# 2) Primitive literals, nil/void, symbols, strings, chars, numbers
# ----------------------------------------------------------------------------

(println "=== 2) literals ===")

(var an_int 42)
(var bigish_int 9223372036854775807)
(var a_float 3.14159)
(var a_bool true)
(var no_value nil)
(var missing_result void)
(var a_char 'G')
(var a_symbol `hello)
(var a_string "Gene")
(var interpolated #"Hello, #{a_string}; policy=#{generated_policy}")

(println an_int a_float a_bool no_value missing_result a_char a_symbol)
(println interpolated)

# Integer overflow throws instead of promoting to bigint.
# RECOMMENDATION: add BigInt for unbounded arithmetic and exact integer-heavy workloads.

# Strings: newline-capable normal strings and interpolation.
(var multiline "line one
line two")
(println multiline)

# RECOMMENDATION: add raw strings, e.g. r"...", for regex patterns, Windows paths, and JSON snippets.


# ----------------------------------------------------------------------------
# 3) Date, DateTime, Time, Bytes, Regex literals
# ----------------------------------------------------------------------------

(println "=== 3) date/time/bytes/regex literals ===")

(var d 2024-01-23)
(var dt1 2024-01-23T20:10)
(var dt2 2024-01-23T20:10:10.123)
(var dtz 2024-01-23T20:10:10Z)
(var t1 10:10)
(var t2 10:10:10.123)

(println d dt1 dt2 dtz t1 t2)
(println "date fields:" (d .year) (d .month) (d .day))
(println "date comparison:" (< 2024-01-01 2024-12-31))

# RECOMMENDATION: consolidate DateTime docs/API: literals exist, but parsing, duration arithmetic,
# timezone conversion, Period/Duration types, and stable timezone accessors need a clearer surface.

(var bytes_bin 0!11110000)
(var bytes_hex 0#a0ff)
(var bytes_b64 0*AQID)
(var hex_int 0xff) # Hex integer, not bytes.

(println bytes_bin bytes_hex bytes_b64 hex_int)
(println "bytes size/get/to_array:" (0#abcd .size) (0#abcd .get 0) (0#abcd .to_array))

# RECOMMENDATION: add full Bytes API: concat, slice, compare, bitwise ops, decode-to-string, encode-from-array.

(var digit_re #/(\d+)/)
(var flagged_re #/pattern/i)
(var replacement_re #/(\d)/[\\1]/)

(println digit_re flagged_re replacement_re)
# RECOMMENDATION: add regex interpolation and verbose `/x` mode:
#   #/#{escaped_pattern}/i
#   #/ verbose pattern /x


# ----------------------------------------------------------------------------
# 4) Gene data structure: type + props + children; quote/unquote/render
# ----------------------------------------------------------------------------

(println "=== 4) Gene data values ===")

(var person_gene `(Person ^name "Ada" ^age 37 (Address ^city "London") "child-1" "child-2"))
(println "gene type:" person_gene/.type)
(println "gene props:" person_gene/.props)
(println "gene children:" person_gene/.children)
(println "gene property lookup:" person_gene/name)
(println "gene child lookup:" person_gene/0)
(println "missing gene prop:" person_gene/missing)

(var title "Feature Tour")
(var template `(section ^class "hero" (h1 %title)))
(println "quoted template:" template)
(println "rendered template:" ($render template))

(var attrs {^class "card" ^id "intro"})
(var children [`(h1 "Title") `(p "Body")])
(var html_gene (`div ^...attrs children...))
(println "gene prop/child spread:" html_gene)

# RECOMMENDATION: add first-class source-span metadata for quoted forms for macro diagnostics.


# ----------------------------------------------------------------------------
# 5) Expressions, operators, assignment, precedence
# ----------------------------------------------------------------------------

(println "=== 5) expressions and operators ===")

(var x 10)
(println "arithmetic:" (10 + 3) (10 - 3) (10 * 3) (10 / 3) (10 % 3))
(println "precedence:" (2 + 3 * 4))
(println "comparison:" (3 == 3) (3 != 4) (5 > 2) (5 >= 5) (4 <= 3))
(println "chained comparison:" (1 < 2 <= 3) (5 > 3 > 1))
(println "logic:" (true && true) (true || false) (true &|& false) (! false))

(x = 20)
(x += 5)
(x -= 2)
(x *= 3)
(x /= 2)
(x %= 5)
(println "assigned x:" x)

(var do_result
  (do
    (var local_a 5)
    (var local_b 8)
    (local_a + local_b)
  )
)
(println "do returns last expression:" do_result)

(println "ifel:" (ifel (x > 10) "large" "small"))


# ----------------------------------------------------------------------------
# 6) Control flow
# ----------------------------------------------------------------------------

(println "=== 6) control flow ===")

(var status "unknown")
(if (x > 10)
  (status = "big")
elif (x == 10)
  (status = "ten")
else
  (status = "small")
)
(println "if/elif/else status:" status)

(var n 0)
(while (n < 3)
  (n += 1)
)
(println "while n:" n)

(var loop_value
  (loop
    (if (n > 10) then (break "done"))
    (n += 1)
    (if (n == 5) then (continue))
    (if (n >= 7) then (break n))
  )
)
(println "loop break value:" loop_value)

(repeat 2
  (println "repeat body")
)

(var total 0)
(for item in [1 2 3 4]
  (total += item)
)
(println "for array total:" total)

(for i value in [10 20 30]
  (println "for index/value:" i value)
)

(for k v in {^alice 90 ^bob 85}
  (println "for map key/value:" k v)
)

(var day 2)
(var day_name
  (case day
    when 1 "Monday"
    when 2 "Tuesday"
    when 3 "Wednesday"
    else "Other"
  )
)
(println "case value:" day_name)

(fn find_first [arr pred]
  (for candidate in arr
    (if (pred candidate) then (return candidate))
  )
  nil
)
(println "return from function:" (find_first [1 3 4 6] (fn [v] ((v % 2) == 0))))

# RECOMMENDATION: add exhaustiveness checking for ADT/enum case expressions.
# RECOMMENDATION: add loop labels for nested break/continue:
#   (loop ^name outer ... (break ^from outer value))


# ----------------------------------------------------------------------------
# 7) Arrays, maps, ranges, collection methods, spread
# ----------------------------------------------------------------------------

(println "=== 7) collections ===")

(var arr [1 2 3])
(println "array:" arr arr/0 arr/-1 arr/99)
(arr/0 = 99)
(println "array after mutation:" arr)

(var left [1 2])
(var right [3 4])
(var both [left... right...])
(println "array spread:" both)

(var matrix [[1 2] [3 4]])
(println "nested array access:" matrix/1/0)

(var popped (do
  (var tmp [1 2 3])
  (tmp .add 4)
  (var last (tmp .pop))
  [tmp last]
))
(println "array add/pop:" popped)

(var nums [5 1 4 2 3])
(println "array size/length/get:" nums/.size nums/.length (nums .get 0))
(println "array map:" (nums .map (fn [v] (v * 2))))
(println "array filter:" (nums .filter (fn [v] ((v % 2) == 0))))
(println "array reduce:" (nums .reduce 0 (fn [acc v] (acc + v))))
(println "array find:" (nums .find (fn [v] (v > 3))))
(println "array zip:" (nums .zip ["a" "b" "c" "d" "e"]))
(println "array reverse:" nums/.reverse)
# (println "array sort:" nums/.sort)
# (println "array slice:" (nums .slice 1 3))
# RECOMMENDATION: clarify exact slice signature and add literal slice syntax: nums[1..3] or nums/1..3.
# RECOMMENDATION: add tuple/fixed-array type for immutable fixed-size records.

(var cfg {^host "localhost" ^port 8080 ^ssl false})
(println "map:" cfg cfg/host cfg/missing)
(cfg/port = 9090)
(println "map after mutation:" cfg)

(var nested {^outer {^inner 123}})
(println "nested map access:" nested/outer/inner)

(var shortcuts {
  ^^enabled       # ^enabled true
  ^!disabled     # ^disabled false
  ^limits^^soft  # ^limits {^soft true}
  ^limits^!hard  # ^limits {^hard false}
})
(println "map shortcuts:" shortcuts/enabled shortcuts/disabled shortcuts/limits/soft shortcuts/limits/hard)

(println "assertion access:" cfg/host/!)
(try
  cfg/missing/!
  catch *
  (println "cfg/missing/! correctly threw:" $ex/message)
)

(println "map size/keys/values:" cfg/.size cfg/.keys cfg/.values)
(println "map contains:" (cfg .contains `host))
(println "map merge:" (cfg .merge {^mode "dev"}))
(println "map filter:" ({^a 1 ^b 2 ^c 3} .filter (fn [k v] (v > 1))))
(println "map reduce:" ({^a 1 ^b 2} .reduce 0 (fn [acc k v] (acc + v))))

# RECOMMENDATION: add stable map destructuring:
#   (var {^host h ^port p rest...} cfg)
# RECOMMENDATION: add ordered/sorted maps where iteration order matters.

(var r1 (0 .. 3))
(var r2 (range 1 5 2))
(var r3 (range 5 1 -2))
(println "ranges:" r1 r2 r3)

(for value in r2
  (println "range item:" value)
)

(var it (r2 .iter))
(println "range iterator:" (it .has_next) (it .next) (it .next_pair))


# ----------------------------------------------------------------------------
# 8) Selectors: path lookup, dynamic segments, selector values, stream mode, set
# ----------------------------------------------------------------------------

(println "=== 8) selectors ===")

(var data {
  ^users [
    {^name "Ada" ^profile {^lang "Gene"}}
    {^name "Bob" ^profile {^lang "Nim"}}
  ]
  ^props {^x 1 ^y 2}
})

(println "slash lookup:" data/users/0/name data/users/-1/profile/lang)
(println "nil receiver stays nil:" nil/name)
(println "missing lookup is void:" data/users/99/name)

(var key "name")
(var idx 1)
(println "dynamic selector segment:" data/users/<idx>/<key>)

(println "explicit ./ selector call:" ({^a "A"} ./ "a") ({} ./ "a" "default"))

(var first_name @users/0/name)
(var all_names @users/*/name)
(println "selector values:" (first_name data) (all_names data))
(println "selector method shorthand:" (data .@users/1/profile/lang))
(println "selector entry expansion:" (@props/** data))
(println "selector collect entries:" ((@ "props" ** @@) data))

($set data @props {^x 10 ^y 20})
(println "after simple $set:" data/props)

