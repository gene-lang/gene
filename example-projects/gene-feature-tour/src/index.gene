(var backlog (new Backlog))
(var task1 (make_task 1 "write language tour" ^priority Priority/high ^owner "Ada"))
(var task2 (make_task 2 "review docs" ^priority Priority/normal))
(var task3 (new TimedTask 3 "publish examples" Priority/urgent "Bob" 2026-04-25T10:00:00Z))

(backlog .add task1)
(backlog .add task2)
(backlog .add task3)

(println "task render:" task1/.render)
(println "timed render with super:" task3/.render)
(println "backlog count/titles:" backlog/.count backlog/.titles)
(task1 .mark_done)
(println "pending tasks:" backlog/.pending)

