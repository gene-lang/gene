(println "=== 9) functions ===")

(fn add [a b] (a + b))
(fn typed_add [a: Int b: Int] -> Int (a + b))
(fn hello [] (println "hello()"))

(var double (fn [v] (v * 2)))

(fn greet [name = "World"]
  #"Hello, #{name}"
)

(fn sum_all [first rest...]
  (var acc first)
  (for v in rest
    (acc += v)
  )
  acc
)

(fn configure [^host ^port = 8080 ^ssl = false ^debug = false]
  {^host host ^port port ^ssl ssl ^debug debug}
)

(println "function calls:" (add 1 2) (typed_add 3 4) (double 5))
(println "default arg:" (greet) (greet "Gene"))
(println "rest arg:" (sum_all 1 2 3 4))
(println "keyword args:" (configure ^host "localhost" ^ssl true))
(println ".call:" (add .call 10 20))

(var counter (make_counter 10))
(println "closure:" (counter) (counter))

(println "generic identity:" (identity 123) (identity "abc"))

(println "function metadata intent:" (function_intent annotated_add))
(println "function metadata examples:" (function_examples annotated_add))

(println "macro-like trace:" (trace! "sum expression" (1 + 2 + 3)))

(var render_subject "world")
(println "rendered quoted form:" ($render `(println "hello" %render_subject)))

