# ----------------------------------------------------------------------------
# 18) JSON, serialization, GIR notes
# ----------------------------------------------------------------------------

(println "=== 18) serialization ===")

(var json_text "{\"name\":\"Ada\",\"age\":37}")
(var parsed (gene/json/parse json_text))
(println "json parse:" parsed parsed/name parsed/age)
(println "json stringify:" (gene/json/stringify {^ok true ^n 1}))

(var tagged (gene/json/serialize person_gene))
(println "tagged gene json:" tagged)
(println "tagged gene json roundtrip:" (gene/json/deserialize tagged))

(var ser_text (gene/serdes/serialize {^name "Ada" ^age 37}))
(println "serdes:" ser_text (gene/serdes/deserialize ser_text))

# GIR is bytecode/cache rather than data serialization:
#   gene compile src/index.gene
#   gene run build/index.gir
#   gene run src/index.gene --no-gir-cache
#
