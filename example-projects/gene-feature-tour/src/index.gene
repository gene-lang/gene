# 13) Errors, exceptions, catch forms, finally, contracts, assert
# ----------------------------------------------------------------------------

(println "=== 13) errors/contracts ===")

(try
  (throw "plain message")
catch e
  (println "caught with binding:" e/message)
)

(try
  (1 / 0)
catch RuntimeException
  (println "caught runtime exception:" $ex/message)
catch Exception
  (println "caught generic exception:" $ex/message)
catch *
  (println "caught fallback:" $ex/message)
finally
  (println "finally always runs")
)

(try
  (positive_add -1 2)
catch *
  (println "contract failure:" $ex/message)
)

(assert (backlog/.count >= 0) "backlog count must never be negative")

