# ----------------------------------------------------------------------------
# 10) Gradual typing, runtime type checks, Result/Option, ADT-style matching
# ----------------------------------------------------------------------------

(println "=== 10) types ===")

(var maybe_name: DisplayName "Ada")
(var maybe_missing: DisplayName nil)

(println "type checks:" (42 is Int) ("hi" is String) ([1] is Array) ({^a 1} is Map))
(println "typeof:" (typeof 42) (typeof "hi") (typeof maybe_name))
(println "union type expression:" (String | Nil))
(println "type equivalence:" (types_equivalent DisplayName `(Nil | String)))

(fn show_name [name: DisplayName] -> String
  (name || "missing")
)
(println "union flow:" (show_name maybe_name) (show_name maybe_missing))

(fn safe_div [a: Int b: Int] -> (Result Float String)
  (if (b == 0)
    (Err "division by zero")
  else
    (Ok (a / b))
  )
)

(var ok_result (safe_div 10 2))
(var err_result (safe_div 10 0))
(println "Result values:" ok_result err_result)

(case ok_result
  when (Ok v) (println "case Ok:" v)
  when (Err e) (println "case Err:" e)
)

(var some_val (Some "value"))
(var none_val None)
(println "Option values:" some_val none_val)

(fn compute_with_question [] -> (Result Float String)
  (var v ((safe_div 10 2) ?))
  (Ok (v * 3))
)
(println "? unwrap:" (compute_with_question))

# ADT/Option matching and ? are documented as experimental.
