(println "note render:" note/.render)

(var score (Scored 99))
(println "external adapter score:" score/.score)

(ns Dynamic
  (.on_member_missing (fn [name] #"Dynamic/#{name}"))
)
(println "namespace on_member_missing:" Dynamic/anything)

