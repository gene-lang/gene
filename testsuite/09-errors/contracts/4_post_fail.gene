# Basic postcondition failure should raise ContractViolation
# ExitCode: 1
# Expected: Error: {^message "ContractViolation: broken_post postcondition #1 failed: (result > x) | args=[x=4] | result=4" ^code "GENE.RUNTIME.ERROR" ^severity "error" ^stage "runtime" ^span {^file "" ^line 0 ^column 0} ^hints [] ^repair_tags ["runtime"]}

(fn broken_post [x: Int] -> Int
  ^post [(result > x)]
  x
)

(broken_post 4)
