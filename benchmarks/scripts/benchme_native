#!/usr/bin/env bash

# Usage:
# benchme_native [gene args...]

echo "=== Gene Benchmark (native code) ==="
echo "Date: $(date '+%Y-%m-%d %H:%M:%S %A')"
echo "Git commit: $(git rev-parse HEAD)"
echo "Nim version: $(nim --version 2>&1 | head -1)"
echo ""

# Run benchmark
echo "Compiling fibonacci_native benchmark..."
rm -f bin/fibonacci_native 2>/dev/null
CMD="nim c --hints:off --mm:orc -d:release -d:danger -d:ssl --out:bin/fibonacci_native benchmarks/computation/fibonacci_native.nim"
$CMD 2>&1 | grep -v "Warning:" | grep -v "ignoring duplicate libraries" || true

if [ -f "./bin/fibonacci_native" ]; then
  echo ""
  echo "Running fibonacci_native benchmark..."
  ./bin/fibonacci_native "$@"
else
  echo "Error: bin/fibonacci_native not found"
  exit 1
fi

