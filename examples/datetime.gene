#!/usr/bin/env gene run

(var today (gene/today))
(var now (gene/now))

(println "today:" today)
(println "today/year:" (today .year))
(println "now:" now)
(println "now/year:" (now .year))
(println "now/hour:" (now .hour))
(println "now/minute:" (now .minute))
(println "now/second:" (now .second))
