#!/usr/bin/env gene run

(var parsed
  (gene/json/parse "{\"ok\": true, \"items\": [1, 2, 3]}")
)
(println "parsed:" parsed)

(var payload
  [
    1 2 3
    {^lang "Gene" ^typed true}
    "some string"
  ]
)
(println "json:" (payload .to_json))

(var tagged (gene/json/serialize `hello))
(println "tagged:" tagged)
(println "roundtrip:" (gene/json/deserialize tagged))
