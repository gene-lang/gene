#!/usr/bin/env gene run

# Requires:
#   nimble buildext

(import genex/sqlite)

(var db (genex/sqlite/open "/tmp/gene_examples.db"))

(db .exec "CREATE TABLE IF NOT EXISTS items (name TEXT)")
(db .exec "DELETE FROM items")
(db .exec "INSERT INTO items (name) VALUES (?)" "alpha")
(db .exec "INSERT INTO items (name) VALUES (?)" "beta")

(println (db .query "SELECT name FROM items ORDER BY name"))

(db .close)
