#!/usr/bin/env gene run

(println "starting timer...")

(var timer (gene/sleep_async 100))
(timer .on_success (fn []
  (println "timer finished")
))
(await timer)

(var sum_future (async (+ 20 22)))
(var product_future (async (* 6 7)))

(println "sum:" (await sum_future))
(println "product:" (await product_future))
