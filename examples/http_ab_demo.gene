#!/usr/bin/env gene run

(import genex/http)

(var port 8088)
(var sleep_ms 200)

(fn app [req]
  (if (req/path == "/")
    (respond 200
      (++
        "http ab demo\n"
        "routes:\n"
        "  /health\n"
        "  /slow\n"))
  elif (req/path == "/health")
    (respond 200 "{\"ok\": true}" {^Content-Type "application/json"})
  elif (req/path == "/slow")
    (sleep sleep_ms)
    (respond 200
      #"slow ok after #{sleep_ms}ms"
      {^Content-Type "text/plain"})
  else
    (respond 404 "not found" {^Content-Type "text/plain"}))
)

(println #"Listening on http://127.0.0.1:#{port}")
(println #"Blocking /slow handler sleeps #{sleep_ms}ms per request")
(println "Try /health and /slow")

(start_server port app)
(run_forever)
