#!/usr/bin/env gene run

# Requires:
#   nimble buildext
#   OPENAI_API_KEY

(import genex/ai)

(var api_key $env/OPENAI_API_KEY)

(if (not api_key)
  (do
    (println "Set OPENAI_API_KEY to run this example.")
    (exit 1)
  )
)

(var base_url
  (if $env/OPENAI_BASE_URL
    $env/OPENAI_BASE_URL
  else
    "https://api.openai.com/v1"
  )
)

(var model
  (if $env/OPENAI_API_MODEL
    $env/OPENAI_API_MODEL
  else
    "gpt-5-mini"
  )
)

(var client (new OpenAIClient {^api_key api_key ^base_url base_url ^model model}))

(var messages
  [
    {^role "system" ^content "You are a friendly assistant."}
    {^role "user" ^content "Say hi in one short sentence."}
  ]
)

(var response (client .chat {^messages messages}))
(println response)
