#!/usr/bin/env gene run

(import genex/http)

(fn app [req]
  (if (req/path == "/")
    (respond 200 "hello from Gene")
  elif (req/path == "/health")
    (respond 200 "{\"ok\": true}" {^Content-Type "application/json"})
  else
    (respond 404 "not found")
  )
)

(println "Listening on http://127.0.0.1:8086")
(println "Try / and /health")

(start_server 8086 app)
(run_forever)
